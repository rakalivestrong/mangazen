{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/proxy/mangadex/:path*",
      "destination": "https://api.mangadex.org/:path*"
    },
    {
      "source": "/api/proxy/covers/:path*",
      "destination": "https://uploads.mangadex.org/covers/:path*"
    },
    {
      "source": "/api/proxy/at-home/server/:chapterId",
      "destination": "https://api.mangadex.org/at-home/server/:chapterId"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
