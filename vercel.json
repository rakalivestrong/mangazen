{
  "rewrites": [
    {
      "source": "/api/proxy/mangadex/:path*",
      "destination": "https://api.mangadex.org/:path*"
    },
    {
      "source": "/api/proxy/covers/:path*",
      "destination": "https://uploads.mangadex.org/covers/:path*"
    },
    {
      "source": "/api/proxy/at-home/:path*",
      "destination": "https://api.mangadex.org/at-home/:path*"
    }
  ]
}
